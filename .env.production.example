# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=previsit
POSTGRES_USER=previsit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql+asyncpg://previsit:CHANGE_ME_STRONG_PASSWORD@db:5432/previsit

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...your-key...
OPENAI_MODEL=gpt-4o-mini

# ── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── Email (real SMTP for production) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=noreply@yourdomain.com

# ── URLs ─────────────────────────────────────────────────────────────────────
# Replace with your actual domain or server IP
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=http://backend:8000

# Used at Next.js build time — must be accessible from the browser
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_STRING
