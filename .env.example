# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Security
SECRET_KEY=dev-secret-key-change-in-production

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
