# Database
DATABASE_URL=postgresql+asyncpg://previsit:previsit@db:5432/previsit

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# Email (Mailhog for local dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@previsit.local

# URLs
# BACKEND_URL — internal Docker service name (used by Next.js server-side proxy)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://backend:8000

# NEXT_PUBLIC_API_URL — accessible from browser (used by frontend JS)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security
SECRET_KEY=dev-secret-key-change-in-production
